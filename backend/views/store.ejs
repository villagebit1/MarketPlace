<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>E-Commerce Products</title>
    <!-- Add your CSS links here, e.g., Bootstrap -->
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <!-- Add any other styles or scripts -->
</head>
<body>
    <div class="container">
        <!-- Conditional: If no keyword, show this section -->
        <div style="font-weight: bold; font-size: 25px; color: black; font-family: MozAnimationDelay;">
            PRODUTOS MAIS AVALIADOS
        </div>
        <!-- ProductCarousel component -->
        <div id="product-carousel">
            <!-- Placeholder for top products carousel -->
            <!-- Example: Images or data for topProducts would go here -->
            <div class="carousel">
                <div class="carousel-item">
                    <img src="/assets/case_when1.jpg" alt="Top Product 1">
                    <h5>Top Product 1</h5>
                    <p>$10.00</p>
                </div>
                <!-- Add more carousel items as needed -->
            </div>
        </div>
        <!-- End conditional -->

        <div style="font-weight: bold; font-size: 25px; color: black; font-family: MozAnimationDelay;">
            PRODUTOS MAIS RECENTES
        </div>

        <!-- Conditional: If loading, show loader -->
        <div class="loader">
            <!-- Loader component -->
            <div class="spinner-border" role="status">
                <span class="sr-only">Loading...</span>
            </div>
        </div>
        <!-- End loading -->

        <!-- Conditional: If error, show message -->
        <div class="alert alert-danger" role="alert">
            <!-- Placeholder for error message -->
            Error message here
        </div>
        <!-- End error -->

        <!-- Else: Show products -->
        <div class="row">
            <!-- Loop over products: For each product, render a column -->
            <div class="col-sm-12 col-md-6 col-lg-4 col-xl-3">
                <!-- Product component -->
                <div class="card">
                    <img src="/assets/case_when2.jpg" class="card-img-top" alt="Product Name">
                    <div class="card-body">
                        <h5 class="card-title">Product Name</h5>
                        <p class="card-text">Product Description</p>
                        <p class="card-text">$10.00</p>
                        <a href="/product/1" class="btn btn-primary">View Product</a>
                    </div>
                </div>
            </div>
            <!-- Repeat the above div for each product -->
            <div class="col-sm-12 col-md-6 col-lg-4 col-xl-3">
                <div class="card">
                    <img src="placeholder-image.jpg" class="card-img-top" alt="Product Name 2">
                    <div class="card-body">
                        <h5 class="card-title">Product Name 2</h5>
                        <p class="card-text">Product Description 2</p>
                        <p class="card-text">$20.00</p>
                        <a href="/product/2" class="btn btn-primary">View Product</a>
                    </div>
                </div>
            </div>
            <!-- Add more product cards as needed -->
        </div>
        <!-- End products -->

        <!-- Paginate component -->
        <nav aria-label="Page navigation">
            <ul class="pagination">
                <li class="page-item active">
                    <a class="page-link" href="?page=1">1</a>
                </li>
                <li class="page-item">
                    <a class="page-link" href="?page=2">2</a>
                </li>
                <!-- Add more page links as needed -->
            </ul>
        </nav>
    </div>

    <!-- Add your JS scripts here, e.g., Bootstrap JS -->
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.5.4/dist/umd/popper.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
</body>
</html>