# 1. Use a lightweight Node.js image
	FROM node:22-alpine

	# 2. Set the working directory inside the container
	WORKDIR /app

	# 3. Copy package files and install production dependencies only
	# This makes builds faster by leveraging Docker's cache
	COPY package*.json ./
	RUN npm install --production

	# 4. Copy the rest of your application code
	COPY . .

	# 5. Document the port the app runs on
	EXPOSE 4000

	# 6. The command to start your app
	CMD ["node", "app.js"]